{
  "version": 2,
  "routes": [
    { "src": "/api/create-checkout", "dest": "/api/payment.js" },
    { "src": "/api/test", "dest": "/api/payment.js" },
    { "src": "/api/verify/(.*)", "dest": "/api/payment.js" },
    { "src": "/api/webhook", "dest": "/api/payment.js" }
  ],
  "builds": [
    { "src": "api/payment.js", "use": "@vercel/node" }
  ]
}